# GridShift server-only configuration.
# Copy this file to .env for local/self-hosted deployments. Never commit real values.

# Required in production for signed/encrypted server cookies and sessions.
GRIDSHIFT_SESSION_SECRET=

# BALLDONTLIE live NFL data. Server-only: never prefix this with VITE_.
GRIDSHIFT_BDL_API_KEY=
GRIDSHIFT_BDL_TIER=goat

# Comma-separated Sleeper league IDs allowed to use paid live scoring.
GRIDSHIFT_LIVE_ALLOWED_LEAGUE_IDS=

# Optional shared code for allowlisted league members before live mode is enabled.
GRIDSHIFT_LIVE_ACCESS_CODE=

# Optional separate cookie secret for live-scoring access cookies.
# If blank, the server should fall back to GRIDSHIFT_SESSION_SECRET.
GRIDSHIFT_LIVE_COOKIE_SECRET=

# Live data cache and rate-limit defaults.
GRIDSHIFT_LIVE_CACHE_TTL_MS=1000
GRIDSHIFT_LIVE_MAX_REQ_PER_MIN=300

# Set false only for local HTTP testing. Production cookies should be secure.
GRIDSHIFT_COOKIE_SECURE=true
